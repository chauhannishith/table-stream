# Copy to .env and adjust for local Docker development.
# Do not commit secrets.

POSTGRES_USER=tablestream
POSTGRES_PASSWORD=tablestream_dev
POSTGRES_DB=tablestream_cloud

DATABASE_URL=postgresql://tablestream:tablestream_dev@postgres:5432/tablestream_cloud

REDIS_URL=redis://redis:6379

# Edge hub subscription gate (MVP manual env override)
SUBSCRIPTION_STATUS=ACTIVE
SUBSCRIPTION_PERIOD_END=2026-12-31T00:00:00Z
HUB_ENTITLED=true
ORG_LEGAL_NAME=Demo Restaurant Pvt Ltd
ORG_GST_NUMBER=29ABCDE1234F1Z5
ORG_PHONE=+91-9000000000

HUB_CONFIG_PATH=/app/apps/edge-server/hub.config.yaml

# Frontends (browser → host machine)
VITE_EDGE_API_URL=http://localhost:8443
VITE_EDGE_WS_URL=ws://localhost:8443/v1/stream

# PowerSync client endpoint (tablet-pos local SQLite sync)
POWERSYNC_URL=http://localhost:8080
